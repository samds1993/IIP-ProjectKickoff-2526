<Window x:Class="WpfBubbelvrienden.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bubbelvrienden" Height="560" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#EAF6FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- MENU -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.ColumnSpan="2" Background="#CFE8FF">
            <Button x:Name="btnMenuStart" Content="Start" Width="100" Margin="5,4,0,4" Click="btnMenuStart_Click"/>
            <Button x:Name="btnMenuLeden" Content="Leden" Width="100" Margin="5,4,0,4" Click="btnMenuLeden_Click"/>
            <Button x:Name="btnMenuTrainingen" Content="Trainingen" Width="100" Margin="5,4,0,4" Click="btnMenuTrainingen_Click"/>
        </StackPanel>

        <!-- START -->
        <Grid x:Name="grdStart" Grid.Row="1" Grid.ColumnSpan="2" Visibility="Visible" d:IsHidden="True">
            <Image x:Name="imgStart"
                   Source="/img/Startpagina_duiken.jpg"
                   Stretch="UniformToFill"
                   Margin="0"/>
        </Grid>
        <Grid x:Name="grdLeden" Grid.Row="1" Grid.ColumnSpan="2" Visibility="Collapsed">
            <Grid x:Name="FormContainer">

                <Label x:Name="lblLeden" Content="Registratie leden" Margin="10,20,540,390" FontSize="20" Width="250" Height="40" FontWeight="Bold"/>

                <Label x:Name="lblLidNaam" Content="Naam" HorizontalAlignment="Left" Margin="50,65,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbNaam" Margin="50,95,510,0" Height="25" VerticalAlignment="Top"/>

                <Label x:Name="lblLidVoornaam" Content="Voornaam" HorizontalAlignment="Left" Margin="350,65,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbVoornaam" Margin="350,95,220,0" Height="25" VerticalAlignment="Top"/>

                <Label x:Name="lblLidRRN" Content="Rijksregisternummer" HorizontalAlignment="Left" Margin="50,125,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbLidRRN" Margin="50,155,515,0" Height="25" VerticalAlignment="Top"/>

                <Label x:Name="lblLidAdres" Content="Adres" HorizontalAlignment="Left" Margin="350,125,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbLidAdres" Margin="350,155,220,0" Height="25" VerticalAlignment="Top"/>

                <Label x:Name="lblLidGSM" Content="Telefoonnummer" HorizontalAlignment="Left" Margin="50,185,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbLidGSM" Margin="50,215,515,0" Height="25" VerticalAlignment="Top"/>

                <Label x:Name="lblLidEmail" Content="Email-adres" HorizontalAlignment="Left" Margin="350,185,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbLidEmail" Margin="350,215,220,0" Height="25" VerticalAlignment="Top"/>

                <Label x:Name="lblLidCertificaat" Content="Certificaat" HorizontalAlignment="Left" Margin="50,245,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <ComboBox x:Name="cbxCertificaat" HorizontalAlignment="Left" Margin="50,275,0,0" VerticalAlignment="Top" Width="235" Height="25">
                    <ComboBoxItem Content="★"/>
                    <ComboBoxItem Content="★★"/>
                    <ComboBoxItem Content="★★★"/>
                    <ComboBoxItem Content="★★★★"/>
                    <ComboBoxItem Content="★★★★★"/>
                </ComboBox>

                <Button x:Name="btnRegistratie"
                        Content="Registreren"
                        HorizontalAlignment="Left"
                        Margin="350,270,0,0"
                        VerticalAlignment="Top"
                        Width="222"
                        Height="30"
                        FontSize="18"
                        FontWeight="Bold"
                        Click="btnRegistratie_Click"/>

                <Button x:Name="btnImportCsv" Content="Import CSV" HorizontalAlignment="Left" Margin="50,320,0,0" VerticalAlignment="Top" Width="110" Height="30" Click="btnImportCsv_Click"/>
                <Button x:Name="btnExportCsv" Content="Export CSV" HorizontalAlignment="Left" Margin="175,320,0,0" VerticalAlignment="Top" Width="110" Height="30" Click="btnExportCsv_Click"/>
                <Button x:Name="btnResetTest" Content="Reset lijst" HorizontalAlignment="Left" Margin="300,320,0,0" VerticalAlignment="Top" Width="110" Height="30" Click="btnResetTest_Click"/>

                <TextBlock x:Name="txtLedenFout"
                           HorizontalAlignment="Left"
                           Margin="50,360,0,0"
                           VerticalAlignment="Top"
                           Width="520"
                           Height="45"
                           TextWrapping="Wrap"
                           Foreground="DarkRed"
                           FontWeight="Bold"/>

                <TextBlock x:Name="txtTest"
                           HorizontalAlignment="Left"
                           Margin="620,35,0,0"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"
                           Height="380"
                           Width="230"
                           FontSize="14"/>

                <TextBlock x:Name="txtEditMember"
                           HorizontalAlignment="Left"
                           Margin="50,415,0,0"
                           TextWrapping="Wrap"
                           Text="Voor het aanpassen van ledeninfo: geef een lid-ID in, klik op Zoek, pas de info hierboven aan en klik daarna op Opslaan."
                           VerticalAlignment="Top"
                           Height="45"
                           Width="520"
                           FontSize="14"
                           FontWeight="Bold"/>

                <Label x:Name="lblLidID" Content="Lid ID-nummer" HorizontalAlignment="Left" Margin="50,465,0,0" VerticalAlignment="Top" FontSize="16"/>
                <TextBox x:Name="txbMemberID" HorizontalAlignment="Left" Margin="170,468,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="22"/>
                <Button x:Name="btnSearchID" Content="Zoek" HorizontalAlignment="Left" Margin="320,466,0,0" VerticalAlignment="Top" Height="25" Width="100" FontWeight="Bold" Click="btnSearchID_Click"/>
                <Button x:Name="btnSaveNewID" Content="Opslaan" HorizontalAlignment="Left" Margin="435,466,0,0" VerticalAlignment="Top" Height="25" Width="100" FontWeight="Bold" Click="btnSaveNewID_Click"/>
            </Grid>
        </Grid>

        <!-- LEDEN -->

        <!-- TRAININGEN -->
        <Grid x:Name="grdTrainingen" Grid.Row="1" Grid.ColumnSpan="2" Visibility="Collapsed">
            <Label x:Name="lblNaamTraining" Content="Naam van de training" HorizontalAlignment="Left" Margin="15,20,0,0" VerticalAlignment="Top" Height="25" Width="150"/>
            <TextBox x:Name="txbNaamTraining" TextWrapping="Wrap" Margin="15,50,665,0" Height="25" VerticalAlignment="Top"/>

            <Label x:Name="lblTitelTraining" Content="Titel van de training" HorizontalAlignment="Left" Margin="15,85,0,0" VerticalAlignment="Top" Height="25" Width="150"/>
            <TextBox x:Name="txbTitelTraining" TextWrapping="Wrap" Margin="15,115,665,0" Height="25" VerticalAlignment="Top"/>

            <Label x:Name="lblTagsTraining" Content="Tags" HorizontalAlignment="Left" Margin="180,20,0,0" VerticalAlignment="Top" Height="25" Width="100"/>
            <ComboBox x:Name="cmbTagsTraining" HorizontalAlignment="Left" Margin="180,50,0,0" VerticalAlignment="Top" Width="130" Height="25">
                <ComboBoxItem Content="Zwembad"/>
                <ComboBoxItem Content="Open water"/>
                <ComboBoxItem Content="Veiligheid"/>
                <ComboBoxItem Content="Nachtduik"/>
                <ComboBoxItem Content="Navigatie"/>
            </ComboBox>

            <Label x:Name="lblInhoudTraining" Content="Inhoud van de training" HorizontalAlignment="Left" Margin="180,85,0,0" VerticalAlignment="Top" Height="25" Width="150"/>
            <TextBox x:Name="txbInhoudTraining" TextWrapping="Wrap" Margin="180,115,500,0" Height="25" VerticalAlignment="Top"/>

            <Label x:Name="lblPlaatsTraining" Content="Plaats van de training" HorizontalAlignment="Left" Margin="345,20,0,0" VerticalAlignment="Top" Height="25" Width="150"/>
            <TextBox x:Name="txbPlaatsTraining" TextWrapping="Wrap" Margin="345,50,335,0" Height="25" VerticalAlignment="Top"/>

            <Label x:Name="lblBeschikbarePlaatsenTraining" Content="Beschikbare plaatsen" HorizontalAlignment="Left" Margin="345,85,0,0" VerticalAlignment="Top" Height="25" Width="150"/>
            <TextBox x:Name="txbBeschikbarePlaatsenTraining" TextWrapping="Wrap" Margin="345,115,335,0" Height="25" VerticalAlignment="Top"/>

            <Label x:Name="lblNiveauTraining" Content="Niveau" HorizontalAlignment="Left" Margin="510,20,0,0" VerticalAlignment="Top" Height="25" Width="100"/>
            <ComboBox x:Name="cmbNiveauTraining" HorizontalAlignment="Left" Margin="510,50,0,0" VerticalAlignment="Top" Width="120" Height="25">
                <ComboBoxItem Content="1"/>
                <ComboBoxItem Content="2"/>
                <ComboBoxItem Content="3"/>
                <ComboBoxItem Content="4"/>
                <ComboBoxItem Content="5"/>
            </ComboBox>

            <Label x:Name="lblDiepteTraining" Content="Diepte" HorizontalAlignment="Left" Margin="510,85,0,0" VerticalAlignment="Top" Height="25" Width="100"/>
            <TextBox x:Name="txbDiepteTraining" TextWrapping="Wrap" Margin="510,115,170,0" Height="25" VerticalAlignment="Top"/>

            <Label x:Name="lblDatumTraining" Content="Datum" HorizontalAlignment="Left" Margin="695,20,0,0" VerticalAlignment="Top" Height="25" Width="80"/>
            <DatePicker x:Name="dapDatumTraining" HorizontalAlignment="Left" Margin="695,50,0,0" VerticalAlignment="Top" Height="25" Width="140"/>

            <Button x:Name="btnTrainingToevoegen" Content="Training toevoegen" HorizontalAlignment="Left" Margin="15,165,0,0" VerticalAlignment="Top" Width="160" Height="30" Click="btnTrainingToevoegen_Click"/>
            <TextBlock x:Name="txtTrainingenInfo" HorizontalAlignment="Left" Margin="15,210,0,0" VerticalAlignment="Top" Width="820" Height="250" TextWrapping="Wrap" FontSize="14"/>
        </Grid>
    </Grid>
</Window>
