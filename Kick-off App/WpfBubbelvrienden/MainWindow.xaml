<Window x:Class="WpfBubbelvrienden.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfBubbelvrienden"
        mc:Ignorable="d"
        Title="Bubbelvrienden" Height="450" Width="800">

    <Window.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Menu x:Name="mnuMainMenu" Grid.ColumnSpan="2">
            <Button x:Name="btnMenuStart" Content="Start" Click="btnMenuStart_Click"/>
            <Button x:Name="btnMenuLeden" Content="Leden" Click="btnMenuLeden_Click"/>
            <Button x:Name="btnMenuTrainingen" Content="Trainingen" Click="btnMenuTrainingen_Click"/>
            <Button x:Name="btnMenuSessies" Content="Sessies" Click="btnMenuSessies_Click"/>
        </Menu>
        <Rectangle x:Name="rctMainContent" Stroke="Black" Margin="0,25,0,0" Grid.ColumnSpan="2"/>
        <Grid x:Name="grdStart" d:IsHidden="True" Grid.ColumnSpan="2">
            <Image x:Name="imgStart" Source="/img/Startpagina_duiken.jpg" Margin="0,25,0,0" Stretch="UniformToFill" d:IsHidden="True"/>
        </Grid>
        <Grid x:Name="grdLeden" Grid.ColumnSpan="2" d:IsHidden="True">
            <Grid x:Name="FormContainer">

                <Label x:Name="lblLeden" Content="Registratie leden" Margin="10,42,536,351" FontSize="24" Width="250" Height="50"/>
                <Label x:Name="lblLidNaam" Content="Naam" HorizontalAlignment="Left" Margin="57,88,0,0" VerticalAlignment="Top" FontSize="18" Width="250" Height="30"/>
                <TextBox x:Name="txbNaam" TextWrapping="Wrap" Text="" Margin="60,122,480,278" Width="250" Height="30"/>
                <Label x:Name="lblLidVoornaam" Content="Voornaam" HorizontalAlignment="Left" Margin="380,88,0,0" VerticalAlignment="Top" FontSize="18" Width="250" Height="30"/>
                <TextBox x:Name="txbVoornaam" TextWrapping="Wrap" Text="" Margin="380,122,160,278" Width="250" Height="30"/>
                <Label x:Name="lblLidRRN" Content="Rijksregisternummer" HorizontalAlignment="Left" Margin="57,160,0,0" VerticalAlignment="Top" FontSize="18" Width="250" Height="30"/>
                <TextBox x:Name="txbLidRRN"
                    TextWrapping="Wrap"
                    Margin="59,194,481,206"
                    Width="250"
                    Height="30">
                    <TextBox.Text>
                        <Binding Path="LidRRN"
                 UpdateSourceTrigger="PropertyChanged"
                 ValidatesOnDataErrors="True">
                            <Binding.ValidationRules>
                                <local:RijksregisterValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <Label x:Name="lblLidAdres" Content="Adres" HorizontalAlignment="Left" Margin="380,160,0,0" VerticalAlignment="Top" FontSize="18" Width="250" Height="30" />
                <TextBox x:Name="txbLidAdres" TextWrapping="Wrap" Text="" Margin="380,194,160,206" Width="250" Height="30"/>
                <Label x:Name="lblLidGSM" Content="Telefoonnummer" HorizontalAlignment="Left" Margin="60,234,0,0" VerticalAlignment="Top" FontSize="18" Width="250" Height="30"/>
                <TextBox x:Name="txbLidGSM"
                    TextWrapping="Wrap"
                    Margin="59,273,481,127"
                    Width="250"
                    Height="30">
                    <TextBox.Text>
                        <Binding Path="LidGSM" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <local:GSMValidationRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <Label x:Name="lblLidEmail" Content="Email-adres" HorizontalAlignment="Left" Margin="380,234,0,0" VerticalAlignment="Top" FontSize="18" Width="250" Height="30"/>
                <TextBox x:Name="txbLidEmail"
                     TextWrapping="Wrap"
                     Margin="380,273,160,127"
                    Width="250"
                    Height="30">
                    <TextBox.Text>
                        <Binding Path="LidEmail" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <local:EmailValidationRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <Label x:Name="lblLidCertificaat" Content="Certificaat" HorizontalAlignment="Left" Margin="60,312,0,0" VerticalAlignment="Top" FontSize="18" Width="250" Height="30"/>
                <ComboBox x:Name="cbxCertificaat" HorizontalAlignment="Left" Margin="60,351,0,0" VerticalAlignment="Top" Width="250" Height="30">
                    <ComboBoxItem Content="★"/>
                    <ComboBoxItem Content="★★"/>
                    <ComboBoxItem Content="★★★"/>
                    <ComboBoxItem Content="★★★★"/>
                    <ComboBoxItem Content="★★★★★"/>
                </ComboBox>
                <Button x:Name="btnRegistratie"
                    Content="Registreren"
                    HorizontalAlignment="Left"
                    Margin="380,351,0,0"
                    VerticalAlignment="Top"
                    Width="250"
                    Height="30"
                    FontSize="22"
                    Click="btnRegistratie_Click"
                    IsEnabled="{Binding ElementName=FormContainer,
                            Path=(Validation.HasError),
                            Converter={StaticResource InverseBoolConverter}}" />
                <TextBlock x:Name="txtTest" HorizontalAlignment="Left" Margin="645,122,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="264" Width="145"/>
                <Button x:Name="btnResetTest" Content="Reset lijst" HorizontalAlignment="Left" Margin="662,363,0,0" VerticalAlignment="Top" Width="107" Click="btnResetTest_Click"/>
            </Grid>
        </Grid>
        <Grid x:Name="grdTrainingen" Grid.ColumnSpan="2">
            <Label x:Name="lblNaamTraining" Content="Naam van de Training" HorizontalAlignment="Left" Margin="5,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbNaamTraining" TextWrapping="Wrap" Margin="5,58,653,358"/>
            <Label x:Name="lblTitelTraining" Content="Titel van de Training" HorizontalAlignment="Left" Margin="5,81,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbTitelTraining" TextWrapping="Wrap" Margin="5,116,653,300"/>
            <Label x:Name="lblTagsTraining" Content="Tags" HorizontalAlignment="Left" Margin="160,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <ComboBox x:Name="cmbTagsTraining" HorizontalAlignment="Left" Margin="160,53,0,0" VerticalAlignment="Top" Width="120"/>
            <Label x:Name="lblInhoudTraining" Content="Inhoud van de Training" HorizontalAlignment="Left" Margin="160,81,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbInhoudTraining" TextWrapping="Wrap" Margin="160,116,498,300"/>
            <Label x:Name="lblPlaatsTraining" Content="Plaats van de Training" HorizontalAlignment="Left" Margin="310,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbPlaatsTraining" TextWrapping="Wrap" Margin="310,58,348,358"/>
            <Label x:Name="lblBeschikbarePlaatsenTraining" Content="Beschikbare plaatsen" HorizontalAlignment="Left" Margin="310,81,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbBeschikbarePlaatsenTraining" TextWrapping="Wrap" Margin="310,116,348,300"/>
            <Label x:Name="lblNiveauTraining" Content="Niveau" HorizontalAlignment="Left" Margin="460,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <ComboBox x:Name="cmbNiveauTraining" HorizontalAlignment="Left" Margin="465,53,0,0" VerticalAlignment="Top" Width="120"/>
            <Label x:Name="lblDiepteTraining" Content="Diepte" HorizontalAlignment="Left" Margin="465,81,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbDiepteTraining" TextWrapping="Wrap" Margin="465,116,193,300"/>
            <Label x:Name="lblDatumTraining" Content="Datum" HorizontalAlignment="Left" Margin="625,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <DatePicker x:Name="dapDatumTraining" HorizontalAlignment="Left" Margin="625,52,0,0" VerticalAlignment="Top" Height="24" Width="134"/>
        </Grid>
        <Grid x:Name="grdSessies" d:IsHidden="True" Grid.ColumnSpan="2">
            <Label x:Name="lblSessies" Content="PLACEHOLDER SESSIES" Margin="0,25,0,0"/>
        </Grid>
    </Grid>
</Window>
