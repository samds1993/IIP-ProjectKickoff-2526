<Window x:Class="WpfBubbelvrienden.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfBubbelvrienden"
        mc:Ignorable="d"
        Title="Bubbelvrienden" Height="484" Width="800">

    <Window.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Menu x:Name="mnuMainMenu" Grid.ColumnSpan="2">
            <Button x:Name="btnMenuStart" Content="Start" Click="btnMenuStart_Click"/>
            <Button x:Name="btnMenuLeden" Content="Leden" Click="btnMenuLeden_Click"/>
            <Button x:Name="btnMenuTrainingen" Content="Trainingen" Click="btnMenuTrainingen_Click"/>
            <Button x:Name="btnMenuSessies" Content="Sessies" Click="btnMenuSessies_Click"/>
        </Menu>

        <Rectangle x:Name="rctMainContent" Stroke="Black" Margin="0,25,0,0" Grid.ColumnSpan="2"/>

        <Grid x:Name="grdStart" Grid.ColumnSpan="2" d:IsHidden="True">
            <Image x:Name="imgStart" Source="/img/Startpagina_duiken.jpg" Margin="0,25,0,0" Stretch="UniformToFill" d:IsHidden="True"/>
        </Grid>

        <Grid x:Name="grdLeden" Grid.ColumnSpan="2" d:IsHidden="True">
            <Grid x:Name="FormContainer">

                <Label x:Name="lblLeden" Content="Registratie leden" Margin="10,33,540,368" FontSize="20" Width="250" Height="50"/>

                <Label x:Name="lblLidNaam" Content="Naam" HorizontalAlignment="Left" Margin="50,60,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbNaam" TextWrapping="Wrap" Text="" Margin="50,95,510,335"/>

                <Label x:Name="lblLidVoornaam" Content="Voornaam" HorizontalAlignment="Left" Margin="350,60,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbVoornaam" TextWrapping="Wrap" Text="" Margin="350,95,220,335"/>

                <Label x:Name="lblLidRRN" Content="Rijksregisternummer" HorizontalAlignment="Left" Margin="600,60,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbLidRRN"
                    TextWrapping="Wrap"
                    Margin="605,95,26,335">
                    <TextBox.Text>
                        <Binding Path="LidRRN"
                 UpdateSourceTrigger="PropertyChanged"
                 ValidatesOnDataErrors="True">
                            <Binding.ValidationRules>
                                <local:RijksregisterValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <!-- NAAM AANGEPAST -->
                <Label x:Name="lblLidStreet" Content="Straatnaam" HorizontalAlignment="Left" Margin="50,128,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30" />
                <TextBox x:Name="txbLidStreet" TextWrapping="Wrap" Text="" Margin="56,157,522,275"/>

                <Label x:Name="lblLidGSM" Content="Telefoonnummer" HorizontalAlignment="Left" Margin="50,180,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbLidGSM"
                    TextWrapping="Wrap"
                    Margin="50,215,515,215">
                    <TextBox.Text>
                        <Binding Path="LidGSM" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <local:GSMValidationRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <Label x:Name="lblLidEmail" Content="Email-adres" HorizontalAlignment="Left" Margin="350,180,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <TextBox x:Name="txbLidEmail"
                     TextWrapping="Wrap"
                     Margin="350,215,220,215">
                    <TextBox.Text>
                        <Binding Path="LidEmail" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <local:EmailValidationRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <Label x:Name="lblLidCertificaat" Content="Certificaat" HorizontalAlignment="Left" Margin="50,235,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30"/>
                <ComboBox x:Name="cbxCertificaat" HorizontalAlignment="Left" Margin="50,270,0,0" VerticalAlignment="Top" Width="235" Height="25">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                </ComboBox>

                <Button x:Name="btnRegistratie"
                    Content="Registreren"
                    HorizontalAlignment="Left"
                    Margin="350,265,0,0"
                    VerticalAlignment="Top"
                    Width="222"
                    Height="30"
                    FontSize="18"
                    Click="btnRegistratie_Click"
                    IsEnabled="{Binding ElementName=FormContainer,
                            Path=(Validation.HasError),
                            Converter={StaticResource InverseBoolConverter}}" FontWeight="Bold" />

                <TextBlock x:Name="txtTest" HorizontalAlignment="Left" Margin="624,37,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="276" Width="166"/>
                <Button x:Name="btnResetTest" Content="Reset lijst" HorizontalAlignment="Left" Margin="624,318,0,0" VerticalAlignment="Top" Width="107" Click="btnResetTest_Click"/>

                <TextBox x:Name="txbMemberID" HorizontalAlignment="Left" Margin="254,390,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="146" Height="21"/>
                <TextBlock x:Name="txtEditMember" HorizontalAlignment="Left" Margin="50,328,0,0" TextWrapping="Wrap" Text="Voor het aanpassen van leden info, geef in lid ID en pas de informatie hierboven aan. Klik daarna op opslaan." VerticalAlignment="Top" Height="47" Width="522" FontSize="16" FontWeight="Bold"/>

                <Label x:Name="lblLidID" Content="Lid ID-nummer" HorizontalAlignment="Left" Margin="43,380,0,0" VerticalAlignment="Top" FontSize="16"/>
                <Button x:Name="btnSearchID" Content="Zoek" HorizontalAlignment="Left" Margin="446,392,0,0" VerticalAlignment="Top" Height="17" Width="134" FontWeight="Bold" Click="btnSearchID_Click"/>
                <Button x:Name="btnSaveNewID" Content="Opslaan" HorizontalAlignment="Left" Margin="446,416,0,0" VerticalAlignment="Top" Height="17" Width="134" FontWeight="Bold" Click="btnSaveNewID_Click"/>
                <!-- NIEUW -->
                <Label x:Name="lblLidStreetNr" Content="Huisnr." HorizontalAlignment="Left" Margin="350,128,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30" />
                <TextBox x:Name="txbLidStreetNr" TextWrapping="Wrap" Text="" Margin="350,157,372,276"/>

                <Label x:Name="lblLidPostcode" Content="Postcode" HorizontalAlignment="Left" Margin="461,128,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30" />
                <TextBox x:Name="txbLidPostcode" TextWrapping="Wrap" Text="" Margin="465,163,220,270"/>

                <Label x:Name="lblLidGemeente" Content="Gemeente" HorizontalAlignment="Left" Margin="605,128,0,0" VerticalAlignment="Top" FontSize="16" Width="250" Height="30" />
                <TextBox x:Name="txbLidGemeente" TextWrapping="Wrap" Text="" Margin="605,163,26,270"/>

            </Grid>
        </Grid>
        <Grid x:Name="grdTrainingen" Grid.ColumnSpan="2" d:IsHidden="True">
            <Label x:Name="lblNaamTraining" Content="Naam van de Training" HorizontalAlignment="Left" Margin="5,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbNaamTraining" TextWrapping="Wrap" Margin="5,58,653,358"/>
            <Label x:Name="lblTitelTraining" Content="Titel van de Training" HorizontalAlignment="Left" Margin="5,81,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbTitelTraining" TextWrapping="Wrap" Margin="5,116,653,300"/>
            <Label x:Name="lblTagsTraining" Content="Tags" HorizontalAlignment="Left" Margin="160,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <ComboBox x:Name="cmbTagsTraining" HorizontalAlignment="Left" Margin="160,53,0,0" VerticalAlignment="Top" Width="120"/>
            <Label x:Name="lblInhoudTraining" Content="Inhoud van de Training" HorizontalAlignment="Left" Margin="160,81,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbInhoudTraining" TextWrapping="Wrap" Margin="160,116,498,300"/>
            <Label x:Name="lblPlaatsTraining" Content="Plaats van de Training" HorizontalAlignment="Left" Margin="310,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbPlaatsTraining" TextWrapping="Wrap" Margin="310,58,348,358"/>
            <Label x:Name="lblBeschikbarePlaatsenTraining" Content="Beschikbare plaatsen" HorizontalAlignment="Left" Margin="310,81,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbBeschikbarePlaatsenTraining" TextWrapping="Wrap" Margin="310,116,348,300"/>
            <Label x:Name="lblNiveauTraining" Content="Niveau" HorizontalAlignment="Left" Margin="460,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <ComboBox x:Name="cmbNiveauTraining" HorizontalAlignment="Left" Margin="465,53,0,0" VerticalAlignment="Top" Width="120"/>
            <Label x:Name="lblDiepteTraining" Content="Diepte" HorizontalAlignment="Left" Margin="465,81,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <TextBox x:Name="txbDiepteTraining" TextWrapping="Wrap" Margin="465,116,193,300"/>
            <Label x:Name="lblDatumTraining" Content="Datum" HorizontalAlignment="Left" Margin="625,23,0,0" VerticalAlignment="Top" Height="30" Width="150"/>
            <DatePicker x:Name="dapDatumTraining" HorizontalAlignment="Left" Margin="625,52,0,0" VerticalAlignment="Top" Height="24" Width="134"/>
            <Button x:Name="btnOpslaanTraining" Margin="638,121,38,314" Content="Opslaan" Click="btnOpslaanTraining_Click"/>
            <TextBlock x:Name="txbTestOutputTraining" HorizontalAlignment="Left" Margin="143,221,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="156" Width="361"/>
        </Grid>
        <!-- NIEUW -->
        <Grid x:Name="grdSessies" Margin="0,0,10,10" Grid.ColumnSpan="2">

            <Label x:Name="lblSessies" Content="Trainingsessies" Margin="278,55,212,320" FontSize="20"/>

            <Label x:Name="lblSelectieTraining" Content="Selecteer de gewenste training" HorizontalAlignment="Left" Margin="20,87,0,0" VerticalAlignment="Top" Height="26" Width="173"/>
            <ListBox ItemsSource="{Binding trainingenLijst}" Margin="18,118,597,0" Height="181" VerticalAlignment="Top">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Naam}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Titel}" />
                            <TextBlock Text="{Binding Datum}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Label x:Name="lblSelectieDuikers" Content="Selecteer de gewenste duikers" HorizontalAlignment="Left" Margin="234,92,0,0" VerticalAlignment="Top" Height="26" Width="170"/>
            <ListBox ItemsSource="{Binding ledenLijst}"
         SelectionMode="Multiple"
         DisplayMemberPath="Naam"
         x:Name="lstDuikers" Margin="225,123,395,159" />
            
            <Button x:Name="btnSelectieDuikers" Content="Selecteer" HorizontalAlignment="Left" Margin="225,321,0,0" VerticalAlignment="Top" Width="85" Click="btnSelectieDuikers_Click"/>



        </Grid>
    </Grid>
</Window>
